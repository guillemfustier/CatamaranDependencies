# Copy this file to /etc/udev/rules.d/99-catamaran-camera.rules
#
# These rules create stable symlinks for the Catamaran cameras based on USB port.
# If cameras are moved to different USB ports in the future, update the KERNELS values.

# Front Fisheye Camera (USB port 3-7)
SUBSYSTEM=="video4linux", KERNELS=="3-7:1.0", ATTR{index}=="0", SYMLINK+="catamaran_fisheye_front"

# Left Fisheye Camera (USB port 3-2)
SUBSYSTEM=="video4linux", KERNELS=="3-2:1.0", ATTR{index}=="0", SYMLINK+="catamaran_fisheye_left"

# Back Fisheye Camera (USB port 3-1)
SUBSYSTEM=="video4linux", KERNELS=="3-1:1.0", ATTR{index}=="0", SYMLINK+="catamaran_fisheye_back"

# Right Fisheye Camera (USB port 3-3)
SUBSYSTEM=="video4linux", KERNELS=="3-3:1.0", ATTR{index}=="0", SYMLINK+="catamaran_fisheye_right"

# Logitech Camera (USB port 3-6)
SUBSYSTEM=="video4linux", KERNELS=="3-6:1.0", SYMLINK+="catamaran_logitech"